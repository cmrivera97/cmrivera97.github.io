---
// i18n
import { getT, type Lang } from '../../i18n/getT';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getT(lang);
---
<div class="theme-toggle" role="group" aria-label={t('theme.toggle')}>
  <button type="button" data-theme-button="light" aria-pressed="false" data-cursor="link">{t('theme.light')}</button>
  <button type="button" data-theme-button="dark" aria-pressed="false" data-cursor="link">{t('theme.dark')}</button>
</div>

<script>
  import { initThemeToggle } from '../../scripts/theme';

  document.querySelectorAll<HTMLElement>('.theme-toggle').forEach((root) => {
    initThemeToggle(root);
  });
</script>

<style>
  .theme-toggle {
    display: inline-flex;
    padding: 3px;
    border-radius: 999px;
    background: rgba(255, 255, 255, .55);
    border: .5px solid var(--c-glass-border);
    backdrop-filter: blur(20px) saturate(160%);
    -webkit-backdrop-filter: blur(20px) saturate(160%);
    box-shadow: 0 1px 0 rgba(255, 255, 255, .7) inset, 0 6px 18px -6px rgba(80, 100, 180, .18);
  }
  :global(:root[data-theme='dark']) .theme-toggle {
    background: rgba(255, 255, 255, .06);
    border-color: rgba(255, 255, 255, .12);
  }
  .theme-toggle button {
    border: 0;
    background: transparent;
    padding: 6px 10px;
    font-size: 13px;
    border-radius: 999px;
    color: var(--c-ink-soft);
    cursor: pointer;
    font-family: inherit;
    transition: all .2s;
    line-height: 1;
  }
  .theme-toggle button[aria-pressed='true'] {
    background: var(--c-ink);
    color: var(--c-bg);
  }
</style>
