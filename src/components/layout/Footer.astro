---
// i18n
import { getT, type Lang } from '../../i18n/getT';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getT(lang);

const socials: ReadonlyArray<{ key: string; href: string; icon: string; label: string }> = [
  {
    key: 'behance',
    href: 'https://www.behance.net/',
    icon: 'behance.svg',
    label: 'Behance',
  },
  {
    key: 'instagram',
    href: 'https://www.instagram.com/',
    icon: 'instagram.svg',
    label: 'Instagram',
  },
  {
    key: 'linkedin',
    href: 'https://www.linkedin.com/',
    icon: 'linkedin.svg',
    label: 'LinkedIn',
  },
  {
    key: 'whatsapp',
    href: 'https://wa.me/',
    icon: 'whatsapp.svg',
    label: 'WhatsApp',
  },
];
---
<footer class="site-footer">
  <p><small>© {new Date().getFullYear()} · {t('home.name.first')} {t('home.name.last')}</small></p>
  <ul role="list" class="socials">
    {socials.map((item) => (
      <li>
        <a href={item.href} aria-label={item.label} rel="noopener noreferrer" target="_blank" data-cursor="link">
          <img src={`${import.meta.env.BASE_URL}icons/${item.icon}`} alt="" width="20" height="20" />
        </a>
      </li>
    ))}
  </ul>
</footer>

<style>
  .site-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem;
    border-top: 1px solid var(--c-line);
    margin-top: 4rem;
  }
  .socials {
    display: flex;
    gap: 0.75rem;
    margin: 0;
  }
  .socials a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 999px;
    color: var(--c-ink);
    background: var(--c-glass);
    border: 0.5px solid var(--c-glass-border);
    transition: background 0.2s, transform 0.2s, border-color 0.2s;
  }
  .socials a:hover {
    transform: translateY(-2px);
  }
  .socials img {
    opacity: 0.9;
  }
  /* The icons are inline-loaded as <img>, so their stroke resolves to the SVG's default
     (dark) currentColor. That reads fine on the light footer but is invisible on the dark
     one, so flip it to white there. */
  :root[data-theme='dark'] .socials img {
    filter: brightness(0) invert(1);
  }
</style>
